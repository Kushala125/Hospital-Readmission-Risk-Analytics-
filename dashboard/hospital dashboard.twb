                <zone h='17250' id='7' name='Readmission Risk vs Patient Risk Score”' pane-specification-id='0' param='[federated.0xs7bht16vtc711ei842v1f6q77y].[avg:Calculation_0898432490336270:qk]' type-v2='size' w='14000' x='2800' y='35250'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone forceUpdate='true' h='15875' id='10' type-v2='text' w='33300' x='9100' y='85375'>
                  <formatted-text>
                    <run fontcolor='#ffffff' fontname='Benton Sans Book'>How does patient risk translate into actual readmission behavior?</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#ffffff' fontname='Benton Sans Book'>As risk score increases, readmission rises steadily — with </run>
                    <run bold='true' fontcolor='#ffffff' fontname='Benton Sans Book'>Rehab and Nursing patients consistently above Home</run>
                    <run fontcolor='#ffffff' fontname='Benton Sans Book'> across all risk levels.</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#ffffff' fontname='Benton Sans Book'>I</run>
                    <run bold='true' fontcolor='#ffffff' fontname='Benton Sans Book'>nsight:</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#ffffff' fontname='Benton Sans Book'>Discharge strategy </run>
                    <run bold='true' fontcolor='#ffffff' fontname='Benton Sans Book'>amplifies underlying risk</run>
                    <run fontcolor='#ffffff' fontname='Benton Sans Book'> — it’s not just patient condition, but post-care decisions that matter.</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone forceUpdate='true' h='12625' id='11' type-v2='text' w='46700' x='52900' y='86625'>
                  <formatted-text>
                    <run fontcolor='#ffffff' fontname='Benton Sans Book'>Which discharge option delivers the best balance between cost and outcomes?</run>
                    <run>Æ&#10;</run>
                    <run bold='true' fontcolor='#ffffff' fontname='Benton Sans Book'>Home</run>
                    <run fontcolor='#ffffff' fontname='Benton Sans Book'> → Lowest readmission, lowest cost </run>
                    <run>Æ&#10;</run>
                    <run bold='true' fontcolor='#ffffff' fontname='Benton Sans Book'>Nursing/Rehab</run>
                    <run fontcolor='#ffffff' fontname='Benton Sans Book'> → Higher cost AND higher readmission </run>
                    <run>Æ&#10;</run>
                    <run bold='true' fontcolor='#ffffff' fontname='Benton Sans Book'>Insight:</run>
                    <run>Æ&#10;</run>
                    <run fontcolor='#ffffff' fontname='Benton Sans Book'>Current system is </run>
                    <run bold='true' fontcolor='#ffffff' fontname='Benton Sans Book'>not optimized</run>
                    <run fontcolor='#ffffff' fontname='Benton Sans Book'> — higher resource allocation is not yielding proportional benefits.</run>
                    <run>Æ&#10;</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
              </zone>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='8' />
              </zone-style>
            </zone>
          </zones>
        </devicelayout>
      </devicelayouts>
      <simple-id uuid='{7475EC02-FA8C-4A47-B066-5D80AFA4D6CC}' />
