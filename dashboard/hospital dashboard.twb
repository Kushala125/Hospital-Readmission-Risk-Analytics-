      <aliases enabled='yes' />
      <column caption='Stage' datatype='string' name='[Calculation_0898432279703552]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [readmitted_30_days] = 1 THEN &quot;4. Readmitted&quot;&#10;ELSEIF [discharge_destination] IN (&quot;Rehab&quot;, &quot;Nursing_Facility&quot;) THEN &quot;3. Rehab/Nursing&quot;&#10;ELSEIF [medication_count] &gt;= 7 OR [length_of_stay] &gt;= 7 THEN &quot;2. High Complexity&quot;&#10;ELSE &quot;1. Total Patients&quot;&#10;END' />
      </column>
      <column caption='Patients' datatype='integer' name='[Calculation_0898432280100865]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([age])' />
      </column>
      <column caption='Med Group' datatype='string' name='[Calculation_0898432476086274]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [medication_count] &lt;= 3 THEN &quot;Low&quot;&#10;ELSEIF [medication_count] &lt;= 6 THEN &quot;Medium&quot;&#10;ELSE &quot;High&quot;&#10;END' />
      </column>
      <column caption='Stay Group' datatype='string' name='[Calculation_0898432476332035]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [length_of_stay] &lt;= 3 THEN &quot;Short&quot;&#10;ELSEIF [length_of_stay] &lt;= 7 THEN &quot;Medium&quot;&#10;ELSE &quot;Long&quot;&#10;END' />
      </column>
      <column caption='Age Groups' datatype='string' name='[Calculation_0898432478683140]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [age] &lt;= 30 THEN &quot;18-30&quot;&#10;ELSEIF [age] &lt;= 50 THEN &quot;30-50&quot;&#10;ELSEIF [age] &lt;= 70 THEN &quot;50-70&quot;&#10;ELSE &quot;70-90&quot;&#10;END' />
      </column>
      <column caption='Medication Groups' datatype='string' name='[Calculation_0898432478793733]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [medication_count] &lt;= 3 THEN &quot;Low&quot;&#10;ELSEIF [medication_count] &lt;= 6 THEN &quot;Medium&quot;&#10;ELSE &quot;High&quot;&#10;END' />
      </column>
      <column caption='Decision Zone' datatype='string' name='[Calculation_0898432480817158]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([readmitted_30_days]) &gt;= WINDOW_AVG(AVG([readmitted_30_days]))&#10;AND AVG([length_of_stay]) &gt;= WINDOW_AVG(AVG([length_of_stay])) THEN &quot;🔥 High Cost + High Risk&quot;&#10;&#10;ELSEIF AVG([readmitted_30_days]) &gt;= WINDOW_AVG(AVG([readmitted_30_days])) THEN &quot;⚠️ High Risk&quot;&#10;&#10;ELSEIF AVG([length_of_stay]) &gt;= WINDOW_AVG(AVG([length_of_stay])) THEN &quot;💰 High Cost&quot;&#10;&#10;ELSE &quot;✅ Efficient&quot;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption=' Experiment Group' datatype='string' name='[Calculation_0898432486686731]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF INDEX() % 2 = 0 THEN &quot;A_Control&quot;&#10;ELSE &quot;B_Treatment&quot;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Risk Score' datatype='real' name='[Calculation_0898432490336270]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([medication_count] * 0.4) + &#10;([diabetes] * 2) + &#10;([length_of_stay] * 0.3)' />
      </column>
      <column caption='Risk Tier' datatype='string' name='[Calculation_0898432490651663]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0898432490336270] &gt; 10 THEN &quot;High Risk&quot;&#10;ELSEIF [Calculation_0898432490336270] &gt; 5 THEN &quot;Medium Risk&quot;&#10;ELSE &quot;Low Risk&quot;&#10;END' />
      </column>
      <column caption='Disease' datatype='string' name='[Calculation_0898432496271377]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [diabetes] = 1 THEN &quot;Diabetic&quot;&#10;ELSE &quot;Non-Diabetic&quot;&#10;END' />
      </column>
      <column caption='Risk Score (bin)' datatype='integer' name='[Risk Score (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='0' formula='[Calculation_0898432490336270]' peg='0' size='1' />
      </column>
