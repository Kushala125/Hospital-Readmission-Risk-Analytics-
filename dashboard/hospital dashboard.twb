      <zones>
        <zone h='33250' id='3' name='Cost vs Risk Efficiency Map' w='33300' x='30000' y='8875' />
        <zone h='9750' id='4' name='Cost vs Risk Efficiency Map' pane-specification-id='0' param='[federated.0xs7bht16vtc711ei842v1f6q77y].[:Measure Names]' type-v2='color' w='16800' x='67900' y='4500' />
