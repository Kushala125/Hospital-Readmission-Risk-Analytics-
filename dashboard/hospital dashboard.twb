  <dashboards>
    <dashboard enable-sort-zone-taborder='true' name='Dashboard 1'>
      <style>
        <style-rule element='table'>
          <format attr='background-color' value='#000000' />
        </style-rule>
      </style>
      <size maxheight='800' maxwidth='1000' minheight='800' minwidth='1000' />
      <datasources>
        <datasource caption='hosp' name='federated.0xs7bht16vtc711ei842v1f6q77y' />
      </datasources>
      <datasource-dependencies datasource='federated.0xs7bht16vtc711ei842v1f6q77y'>
        <column caption='Med Group' datatype='string' name='[Calculation_0898432476086274]' role='dimension' type='nominal'>
          <calculation class='tableau' formula='IF [medication_count] &lt;= 3 THEN &quot;Low&quot;&#10;ELSEIF [medication_count] &lt;= 6 THEN &quot;Medium&quot;&#10;ELSE &quot;High&quot;&#10;END' />
        </column>
        <column caption='Age Groups' datatype='string' name='[Calculation_0898432478683140]' role='dimension' type='nominal'>
          <calculation class='tableau' formula='IF [age] &lt;= 30 THEN &quot;18-30&quot;&#10;ELSEIF [age] &lt;= 50 THEN &quot;30-50&quot;&#10;ELSEIF [age] &lt;= 70 THEN &quot;50-70&quot;&#10;ELSE &quot;70-90&quot;&#10;END' />
        </column>
        <column-instance column='[Calculation_0898432476086274]' derivation='None' name='[none:Calculation_0898432476086274:nk]' pivot='key' type='nominal' />
        <column-instance column='[Calculation_0898432478683140]' derivation='None' name='[none:Calculation_0898432478683140:nk]' pivot='key' type='nominal' />
      </datasource-dependencies>
      <zones>
        <zone h='26000' id='5' name='Readmission Risk Heatmap (Patient Complexity)' w='33800' x='57400' y='6750' />
        <zone h='9500' id='6' name='Readmission Risk Heatmap (Patient Complexity)' pane-specification-id='0' param='[federated.0xs7bht16vtc711ei842v1f6q77y].[avg:readmitted_30_days:qk]' type-v2='color' w='14000' x='84700' y='2375' />
        <zone h='26000' id='7' name='Cohort Analysis (Time / Group Behavior)' w='30000' x='4300' y='56125' />
        <zone forceUpdate='true' h='16875' id='11' type-v2='text' w='39000' x='5500' y='39375'>
          <formatted-text>
            <run bold='true' fontcolor='#ffffff' fontname='Benton Sans Book'>1) Are certain discharge decisions leading to worse outcomes?</run>
            <run>Æ&#10;</run>
            <run fontcolor='#ffffff' fontname='Benton Sans Book'>Patients sent to </run>
            <run bold='true' fontcolor='#ffffff' fontname='Benton Sans Book'>Rehab (~17.5%) and Nursing (~16.8%)</run>
            <run fontcolor='#ffffff' fontname='Benton Sans Book'> have significantly higher readmission rates than those sent </run>
            <run bold='true' fontcolor='#ffffff' fontname='Benton Sans Book'>Home (~10%)</run>
            <run fontcolor='#ffffff' fontname='Benton Sans Book'>.</run>
            <run>Æ&#10;</run>
            <run fontcolor='#ffffff' fontname='Benton Sans Book'>🔥 </run>
            <run bold='true' fontcolor='#ffffff' fontname='Benton Sans Book'>Insight:</run>
            <run>Æ&#10;</run>
            <run fontcolor='#ffffff' fontname='Benton Sans Book'>Discharge destination is not neutral — it reflects </run>
            <run bold='true' fontcolor='#ffffff' fontname='Benton Sans Book'>underlying patient risk AND possible decision gaps</run>
            <run fontcolor='#ffffff' fontname='Benton Sans Book'>. </run>
          </formatted-text>
        </zone>
        <zone forceUpdate='true' h='15875' id='12' type-v2='text' w='35700' x='60500' y='32375'>
          <formatted-text>
            <run bold='true' fontcolor='#ffffff' fontname='Benton Sans Book'>Which combination of patient factors creates the highest risk</run>
            <run fontcolor='#ffffff' fontname='Benton Sans Book'>?</run>
            <run>Æ&#10;&#10;</run>
            <run fontcolor='#ffffff' fontname='Benton Sans Book'>Patients with </run>
            <run bold='true' fontcolor='#ffffff' fontname='Benton Sans Book'>long stays + high medication load</run>
            <run fontcolor='#ffffff' fontname='Benton Sans Book'> show the highest readmission (~12.9%+).</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#ffffff' fontname='Benton Sans Book'>Insight:</run>
            <run>Æ&#10;</run>
            <run fontcolor='#ffffff' fontname='Benton Sans Book'>Risk is </run>
            <run bold='true' fontcolor='#ffffff' fontname='Benton Sans Book'>compounded</run>
            <run fontcolor='#ffffff' fontname='Benton Sans Book'>, not isolated — multiple stress factors amplify readmission probability. </run>
          </formatted-text>
        </zone>
        <zone h='33250' id='13' name='Wrong Discharge by Age &amp; Disease' w='35300' x='58300' y='51000' />
        <zone h='33250' id='14' name='Readmission by Discharge Destination' w='33300' x='7000' y='6125' />
        <zone h='9750' id='15' name='Readmission by Discharge Destination' pane-specification-id='0' param='[federated.0xs7bht16vtc711ei842v1f6q77y].[none:discharge_destination:nk]' type-v2='color' w='14000' x='40300' y='6125' />
        <zone forceUpdate='true' h='15875' id='16' type-v2='text' w='33300' x='5100' y='82875'>
          <formatted-text>
            <run bold='true' fontcolor='#ffffff' fontname='Benton Sans Book'>Do certain patient groups consistently behave as high-risk over time, or is readmission random?</run>
            <run>Æ&#10;</run>
            <run fontcolor='#ffffff' fontname='Benton Sans Book'>Patients in the </run>
            <run bold='true' fontcolor='#ffffff' fontname='Benton Sans Book'>high medication group cluster tightly</run>
            <run fontcolor='#ffffff' fontname='Benton Sans Book'>, showing repeated high-risk behavior rather than isolated spikes.</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#ffffff' fontname='Benton Sans Book'>Insight:</run>
            <run>Æ&#10;</run>
            <run fontcolor='#ffffff' fontname='Benton Sans Book'>Readmission is </run>
            <run bold='true' fontcolor='#ffffff' fontname='Benton Sans Book'>systematic and predictable</run>
            <run fontcolor='#ffffff' fontname='Benton Sans Book'>, not random — enabling </run>
            <run bold='true' fontcolor='#ffffff' fontname='Benton Sans Book'>early identification and intervention</run>
            <run fontcolor='#ffffff' fontname='Benton Sans Book'>.</run>
            <run>Æ&#10;</run>
          </formatted-text>
        </zone>
        <zone forceUpdate='true' h='16000' id='17' type-v2='text' w='33300' x='58600' y='84875'>
          <formatted-text>
            <run bold='true' fontcolor='#ffffff' fontname='Benton Sans Book'>Which patient group is most at risk due to poor discharge decisions?</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#ffffff' fontname='Benton Sans Book'>Older diabetic patients</run>
            <run fontcolor='#ffffff' fontname='Benton Sans Book'> show the highest readmission intensity, especially when discharged home.</run>
            <run>Æ&#10;</run>
            <run fontcolor='#ffffff' fontname='Benton Sans Book'>Æ </run>
            <run bold='true' fontcolor='#ffffff' fontname='Benton Sans Book'>Insight:</run>
            <run>Æ&#10;</run>
            <run fontcolor='#ffffff' fontname='Benton Sans Book'>Discharge strategy is </run>
            <run bold='true' fontcolor='#ffffff' fontname='Benton Sans Book'>not aligned with patient vulnerability</run>
            <run fontcolor='#ffffff' fontname='Benton Sans Book'> — high-risk groups are not receiving sufficient post-care support.</run>
          </formatted-text>
        </zone>
